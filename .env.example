# QQ 机器人凭证 (https://q.qq.com 开放平台获取)
QQ_BOT_APPID=your_app_id_here
QQ_BOT_SECRET=your_client_secret_here

# DeepSeek API 配置
# 获取地址: https://platform.deepseek.com/
LLM_PROVIDER=deepseek
LLM_MODEL=deepseek-chat
LLM_API_KEY=sk-your-deepseek-api-key-here
LLM_BASE_URL=https://api.deepseek.com

# OpenViking 上下文数据库配置（可选）
# 本地部署: 默认 http://localhost:1933，无需 API Key
# 云上版本: 填写火山引擎 OpenViking endpoint，需填写 API Key
# 文档: https://www.volcengine.com/docs/84313/2381937
OPENVIKING_ENABLED=false
OPENVIKING_BASE_URL=http://localhost:1933
OPENVIKING_API_KEY=
OPENVIKING_ACCOUNT=
OPENVIKING_USER=
